FROM prom/prometheus:v3.10.0
USER root

# We use sed (built-in to the image), so no need for the builder stage
COPY prom.yml /etc/prometheus/prom.yml.template
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
# Ensure we tell Prometheus where to listen for Railway
CMD ["--config.file=/etc/prometheus/prom.yml", "--storage.tsdb.path=/prometheus"]